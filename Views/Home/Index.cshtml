@using CarDelership.Models.ViewModels
@model HomeViewModel
@{
    ViewData["Title"] = "Главная";
}

<!-- Герой секция -->
<div class="hero-section text-center">
    <div class="container">
        <h1 class="display-4 fw-bold">Хорошие машины продаются здесь</h1>
        <p class="lead">Легковые автомобили от ведущих производителей</p>
    </div>
</div>

<div class="container">
    <!-- Популярные товары -->
    <section class="popular-products mb-5">
        <div class="text-center mb-4">
            <h2 class="display-5 fw-bold">🔥 Популярные автомобили</h2>
            <p class="text-muted">Самые востребованные модели этого месяца</p>
        </div>

        @if (Model.PopularCars != null && Model.PopularCars.Any())
        {
            <div class="row g-4">
                @foreach (var car in Model.PopularCars)
                {
                    <div class="col-md-3 col-sm-6">
                        <div class="card car-card h-100">
                            <div style="position: relative;">
                                @{
                                    var discountPercent = 0;
                                    if (car.DiscountPrice > 0 && car.DiscountPrice < car.Price)
                                    {
                                        discountPercent = (int)((1 - (double)car.DiscountPrice / (double)car.Price) * 100);
                                    }
                                }
                                @if (discountPercent > 0)
                                {
                                    <div class="discount-badge">-@discountPercent%</div>
                                }
                                <!-- Используем изображение-заглушку, так как поля ImageUrl нет -->
                                <img src="/images/cars/default-car.jpg" class="card-img-top" alt="@car.Name">
                            </div>
                            <div class="card-body">
                                <h5 class="card-title">@car.Name</h5>
                                <p class="card-text text-muted small">@car.Year г.</p>
                                <div class="price-block mb-2">
                                    @if (discountPercent > 0)
                                    {
                                        <span class="car-old-price">@car.Price.ToString("N0") ₽</span>
                                        <span class="car-price">@car.DiscountPrice.ToString("N0") ₽</span>
                                    }
                                    else
                                    {
                                        <span class="car-price">@car.Price.ToString("N0") ₽</span>
                                    }
                                </div>
                                <div class="d-flex gap-2 mt-3">
                                    <button class="btn btn-yellow flex-grow-1 add-to-cart-btn" data-car-id="@car.Car_Id">
                                        🛒 В корзину
                                    </button>
                                    <button class="btn btn-outline-secondary add-to-wishlist" data-car-id="@car.Car_Id">
                                        ❤️
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <p class="text-muted">Нет доступных автомобилей</p>
            </div>
        }

        <div class="text-center mt-5">
            <a href="/Catalog" class="btn btn-outline-yellow btn-lg px-5 py-2">
                Смотреть весь каталог →
            </a>
        </div>
    </section>

    <!-- Преимущества компании -->
    <section class="features mb-5 py-5 bg-light rounded-4">
        <div class="row text-center">
            <div class="col-md-3">
                <div class="feature-box">
                    <div class="feature-icon">
                        <i class="bi bi-truck"></i>
                    </div>
                    <h5>Бесплатная доставка</h5>
                    <p class="text-muted small">При заказе от 1 000 000 ₽</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="feature-box">
                    <div class="feature-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h5>Гарантия качества</h5>
                    <p class="text-muted small">Все авто проходят проверку</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="feature-box">
                    <div class="feature-icon">
                        <i class="bi bi-arrow-repeat"></i>
                    </div>
                    <h5>Обмен и возврат</h5>
                    <p class="text-muted small">14 дней на возврат</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="feature-box">
                    <div class="feature-icon">
                        <i class="bi bi-headset"></i>
                    </div>
                    <h5>Поддержка 24/7</h5>
                    <p class="text-muted small">Всегда на связи</p>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        // Добавление в корзину через AJAX
        $(document).ready(function() {
            $('.add-to-cart-btn').click(function(e) {
                e.stopPropagation();
                var carId = $(this).data('car-id');
                var button = $(this);

                $.ajax({
                    url: '/Cart/AddToCart',
                    type: 'POST',
                    data: { carId: carId, quantity: 1 },
                    beforeSend: function() {
                        button.html('⏳ Добавление...');
                        button.prop('disabled', true);
                    },
                    success: function(response) {
                        if (response.success) {
                            button.html('✓ Добавлено');
                            setTimeout(function() {
                                button.html('🛒 В корзину');
                                button.prop('disabled', false);
                            }, 2000);
                            updateCartCount();
                            showNotification('Товар добавлен в корзину!', 'success');
                        } else {
                            button.html('🛒 В корзину');
                            button.prop('disabled', false);
                            showNotification(response.message || 'Ошибка при добавлении', 'error');
                        }
                    },
                    error: function() {
                        button.html('🛒 В корзину');
                        button.prop('disabled', false);
                        showNotification('Произошла ошибка. Попробуйте позже.', 'error');
                    }
                });
            });

            $('.add-to-wishlist').click(function(e) {
                e.stopPropagation();
                var carId = $(this).data('car-id');
                var button = $(this);

                $.ajax({
                    url: '/Wishlist/AddToWishlist',
                    type: 'POST',
                    data: { carId: carId },
                    success: function(response) {
                        if (response.success) {
                            button.html('💛');
                            showNotification('Добавлено в избранное!', 'success');
                        } else {
                            showNotification(response.message || 'Ошибка', 'error');
                        }
                    }
                });
            });
        });

        function updateCartCount() {
            $.get('/Cart/GetCartCount', function(data) {
                $('#cart-count').text(data.count);
            });
        }

        function showNotification(message, type) {
            if (type === 'success') {
                Swal.fire({
                    icon: 'success',
                    title: 'Готово!',
                    text: message,
                    timer: 1500,
                    showConfirmButton: false
                });
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Ошибка',
                    text: message,
                    timer: 2000
                });
            }
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
}