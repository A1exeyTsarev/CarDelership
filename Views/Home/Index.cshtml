@using CarDelership.Models.ViewModels
@model HomeViewModel
@{
    ViewData["Title"] = "Главная";
}

<!-- Герой секция с черно-желтым градиентом -->
<div class="hero-section text-center">
    <div class="container">
        <h1 class="hero-title">🏁 Хорошие машины продаются здесь</h1>
        <p class="hero-subtitle">Легковые автомобили от ведущих производителей</p>
        <a href="/Account/Login" class="btn btn-yellow btn-lg mt-3 px-5 py-2 rounded-pill">
            🔐 Войти в каталог
        </a>
    </div>
</div>

<div class="container">
    <section class="popular-products mb-5">
        <div class="text-center mb-4">
            
            <p class="text-muted mt-2">Самые востребованные модели этого месяца</p>
        </div>

        @if (Model.PopularCars != null && Model.PopularCars.Any())
        {
            <div class="row g-4">
                @foreach (var car in Model.PopularCars)
                {
                    <div class="col-md-3 col-sm-6">
                        <div class="card car-card h-100">
                            <div style="position: relative; height: 200px; overflow: hidden;">
                                @{
                                    var discountPercent = 0;
                                    if (car.DiscountPrice > 0 && car.DiscountPrice < car.Price)
                                    {
                                        discountPercent = (int)((1 - (double)car.DiscountPrice / (double)car.Price) * 100);
                                    }
                                }
                                @if (discountPercent > 0)
                                {
                                    <div class="discount-badge">
                                        -@discountPercent%
                                    </div>
                                }

                                @* ВЫВОДИМ ПЕРВУЮ КАРТИНКУ ИЗ ГАЛЕРЕИ *@
                                @{
                                    var imagePath = "/images/logo.jpg"; // по умолчанию
                                    if (car.CarImages != null && car.CarImages.Any())
                                    {
                                        imagePath = "/images/" + car.CarImages.First().ImageName;
                                    }
                                }
                                <img src="@imagePath" class="card-img-top" style="width: 100%; height: 100%; object-fit: cover;" alt="@car.Name">
                            </div>
                            <div class="card-body">
                                <h5 class="card-title">@car.Name</h5>
                                <p class="text-muted small">@car.Year г.</p>
                                <div>
                                    @if (discountPercent > 0)
                                    {
                                        <span class="car-old-price">@car.Price.ToString("N0") ₽</span>
                                        <br />
                                        <strong class="car-price">@car.DiscountPrice.ToString("N0") ₽</strong>
                                    }
                                    else
                                    {
                                        <strong class="car-price">@car.Price.ToString("N0") ₽</strong>
                                    }
                                </div>
                                <div class="d-flex gap-2 mt-3">
                                    <button class="btn btn-yellow flex-grow-1 add-to-cart-btn" data-car-id="@car.Car_Id">🛒 В корзину</button>
                                    <button class="btn btn-outline-yellow add-to-wishlist" data-car-id="@car.Car_Id">❤️</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <p class="text-muted">Нет доступных автомобилей</p>
            </div>
        }

        <div class="text-center mt-5">
            <a href="/Catalog" class="btn btn-outline-yellow btn-lg px-5 py-2 rounded-pill">Смотреть весь каталог →</a>
        </div>
    </section>
</div>
