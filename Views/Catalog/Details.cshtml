@model CarDelership.Models.Cars
@{
    ViewData["Title"] = Model?.Name ?? "Автомобиль";
}

<!-- Генерация AntiForgeryToken -->
@Html.AntiForgeryToken()

@if (Model != null)
{
    <div class="container my-5">
        <div class="row">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                    @{
                        var mainImage = Model.CarImages?.FirstOrDefault();
                        string imagePath = mainImage != null && !string.IsNullOrEmpty(mainImage.ImageName)
                        ? $"/images/{mainImage.ImageName}"
                        : "/images/logo.jpg";
                    }
                    <img src="@imagePath"
                         class="img-fluid"
                         alt="@Model.Name"
                         style="min-height: 300px; object-fit: cover;"
                         onerror="this.src='/images/logo.jpg'" />
                </div>
            </div>

            <div class="col-md-6">
                <h1 class="fw-bold mb-3">@Model.Name</h1>

                <div class="mb-3">
                    <span class="badge bg-secondary">@Model.Year год</span>
                    <span class="badge bg-secondary ms-2">@Model.Mileage.ToString("N0") км</span>
                    @if (Model.AvailabilityStatus == "В наличии")
                    {
                        <span class="badge bg-success ms-2">В наличии</span>
                    }
                    else
                    {
                        <span class="badge bg-warning ms-2">@Model.AvailabilityStatus</span>
                    }
                </div>

                <hr>

                <div class="row mb-4">
                    <div class="col-6">
                        <small class="text-muted">Производитель</small>
                        <p class="fw-bold mb-0">@Model.Model?.Manufacturer?.Name</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">Модель</small>
                        <p class="fw-bold mb-0">@Model.Model?.Name</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">Кузов</small>
                        <p class="fw-bold mb-0">@Model.Model?.BodyType?.Name</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">Цвет</small>
                        <p class="fw-bold mb-0">@Model.Color?.Name</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">Двигатель</small>
                        <p class="fw-bold mb-0">@Model.Model?.EngineType?.Name</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">Мощность</small>
                        <p class="fw-bold mb-0">@Model.Model?.Power л.с.</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">КПП</small>
                        <p class="fw-bold mb-0">@Model.Model?.Transmission?.Name</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">VIN номер</small>
                        <p class="fw-bold mb-0">@(Model.VIN ?? "Не указан")</p>
                    </div>
                </div>

                <hr>

                @{
                    var discountPercent = 0;
                    if (Model.DiscountPrice > 0 && Model.DiscountPrice < Model.Price)
                    {
                        discountPercent = (int)((1 - (double)Model.DiscountPrice / (double)Model.Price) * 100);
                    }
                }

                @if (discountPercent > 0)
                {
                    <div class="mb-3">
                        <small class="text-muted text-decoration-line-through">@Model.Price.ToString("N0") ₽</small>
                        <span class="fs-1 text-warning fw-bold">@Model.DiscountPrice.ToString("N0") ₽</span>
                        <span class="badge bg-warning text-dark fs-6 ms-2">-@discountPercent%</span>
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <span class="fs-1 text-warning fw-bold">@Model.Price.ToString("N0") ₽</span>
                    </div>
                }

                <div class="mt-4">
                    <button class="btn btn-yellow btn-lg w-100 add-to-cart-btn" data-car-id="@Model.Car_Id">
                        <i class="bi bi-cart-plus"></i> Добавить в корзину
                    </button>
                    <button class="btn btn-outline-yellow btn-lg w-100 mt-2 add-to-wishlist-btn" data-car-id="@Model.Car_Id">
                        <i class="bi bi-heart"></i> Добавить в избранное
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="row mt-5">
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-3">
                        <div class="card-header bg-white border-0">
                            <h5 class="mb-0 fw-bold">
                                <i class="bi bi-file-text text-warning"></i> Описание
                            </h5>
                        </div>
                        <div class="card-body">
                            <p class="mb-0">@Model.Description</p>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- БЛОК ОТЗЫВОВ -->
        <div class="row mt-5">
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-header bg-white border-0">
                        <h5 class="mb-0 fw-bold">
                            <i class="bi bi-chat-dots text-warning"></i> Отзывы
                            <span id="commentsCount" class="badge bg-secondary ms-2">0</span>
                        </h5>
                    </div>
                    <div class="card-body">
                        <!-- Форма добавления комментария -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Оставить отзыв</label>
                            <textarea id="commentText" class="form-control mb-2" rows="3"
                                  placeholder="Поделитесь своим мнением об автомобиле..."></textarea>
                            <button id="submitCommentBtn" class="btn btn-yellow" data-car-id="@Model.Car_Id">
                                <i class="bi bi-send"></i> Отправить отзыв
                            </button>
                        </div>

                        <hr>

                        <!-- Список комментариев -->
                        <div id="commentsList">
                            <div class="text-center text-muted py-3">
                                <i class="bi bi-chat-dots"></i> Загрузка отзывов...
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12">
                <a href="/Catalog" class="btn btn-outline-yellow">
                    <i class="bi bi-arrow-left"></i> Назад в каталог
                </a>
            </div>
        </div>
    </div>
}
else
{
    <div class="container my-5">
        <div class="alert alert-danger text-center">
            <h3><i class="bi bi-exclamation-triangle"></i> Автомобиль не найден</h3>
            <a href="/Catalog" class="btn btn-yellow mt-3">Вернуться в каталог</a>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            var carId = @Model.Car_Id;

            // Функция загрузки комментариев
            function loadComments() {
                $.ajax({
                    url: '/Comment/GetComments',
                    type: 'GET',
                    data: { carId: carId },
                    success: function(comments) {
                        $('#commentsCount').text(comments.length);

                        if (comments.length === 0) {
                            $('#commentsList').html(`
                                <div class="text-center text-muted py-4">
                                    <i class="bi bi-chat-dots fs-1"></i>
                                    <p class="mt-2">Пока нет отзывов. Будьте первым!</p>
                                </div>
                            `);
                            return;
                        }

                        var html = '';
                        for (var i = 0; i < comments.length; i++) {
                            var comment = comments[i];
                            html += `
                                <div class="comment-item mb-3 p-3 border rounded" id="comment-${comment.id}">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <strong class="fw-bold">
                                                <i class="bi bi-person-circle"></i> ${escapeHtml(comment.authorName)}
                                            </strong>
                                            <small class="text-muted ms-2">${comment.createdAt}</small>
                                        </div>
                                        ${comment.isOwner ? `
                                            <button class="btn btn-sm btn-outline-danger delete-comment-btn" data-comment-id="${comment.id}">
                                                <i class="bi bi-trash"></i> Удалить
                                            </button>
                                        ` : ''}
                                    </div>
                                    <p class="mb-0">${escapeHtml(comment.commentText)}</p>
                                </div>
                            `;
                        }
                        $('#commentsList').html(html);
                    },
                    error: function() {
                        $('#commentsList').html(`
                            <div class="alert alert-danger">
                                <i class="bi bi-exclamation-triangle"></i> Ошибка загрузки отзывов
                            </div>
                        `);
                    }
                });
            }

            // Функция экранирования HTML
            function escapeHtml(text) {
                if (!text) return '';
                var map = {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#39;'
                };
                return text.replace(/[&<>"']/g, function(m) { return map[m]; });
            }

            // Отправка комментария
            $('#submitCommentBtn').click(function() {
                var commentText = $('#commentText').val().trim();

                if (!commentText) {
                    showCommentError('Пожалуйста, введите текст отзыва');
                    return;
                }

                if (commentText.length > 2000) {
                    showCommentError('Отзыв не должен превышать 2000 символов');
                    return;
                }

                var button = $(this);
                var originalHtml = button.html();
                button.html('<i class="bi bi-hourglass-split"></i> Отправка...');
                button.prop('disabled', true);

                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '/Comment/Add',
                    type: 'POST',
                    data: {
                        carId: carId,
                        commentText: commentText
                    },
                    headers: {
                        'RequestVerificationToken': token
                    },
                    success: function(response) {
                        if (response.success) {
                            $('#commentText').val('');
                            loadComments();
                            showCommentSuccess('Отзыв успешно добавлен!');
                        } else {
                            showCommentError(response.message || 'Ошибка при добавлении отзыва');
                        }
                        button.html(originalHtml);
                        button.prop('disabled', false);
                    },
                    error: function(xhr) {
                        let errorMessage = 'Ошибка при добавлении отзыва';
                        if (xhr.status === 401) {
                            errorMessage = 'Необходимо войти в систему';
                            setTimeout(function() {
                                window.location.href = '/Account/Login';
                            }, 2000);
                        }
                        showCommentError(errorMessage);
                        button.html(originalHtml);
                        button.prop('disabled', false);
                    }
                });
            });

            // Удаление комментария
            $(document).on('click', '.delete-comment-btn', function() {
                var commentId = $(this).data('comment-id');
                var button = $(this);

                if (confirm('Вы уверены, что хотите удалить этот отзыв?')) {
                    button.html('<i class="bi bi-hourglass-split"></i>');
                    button.prop('disabled', true);

                    var token = $('input[name="__RequestVerificationToken"]').val();

                    $.ajax({
                        url: '/Comment/Delete',
                        type: 'POST',
                        data: { commentId: commentId },
                        headers: {
                            'RequestVerificationToken': token
                        },
                        success: function(response) {
                            if (response.success) {
                                loadComments();
                                showCommentSuccess('Отзыв удален');
                            } else {
                                showCommentError(response.message || 'Ошибка при удалении');
                                button.html('<i class="bi bi-trash"></i> Удалить');
                                button.prop('disabled', false);
                            }
                        },
                        error: function() {
                            showCommentError('Ошибка при удалении отзыва');
                            button.html('<i class="bi bi-trash"></i> Удалить');
                            button.prop('disabled', false);
                        }
                    });
                }
            });

            // Функции для отображения сообщений
            function showCommentError(message) {
                var errorDiv = $('<div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">' +
                    '<i class="bi bi-exclamation-triangle-fill me-2"></i>' + message +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                    '</div>');
                $('#submitCommentBtn').after(errorDiv);
                setTimeout(function() { errorDiv.fadeOut('slow', function() { $(this).remove(); }); }, 5000);
            }

            function showCommentSuccess(message) {
                var successDiv = $('<div class="alert alert-success alert-dismissible fade show mt-2" role="alert">' +
                    '<i class="bi bi-check-circle-fill me-2"></i>' + message +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                    '</div>');
                $('#submitCommentBtn').after(successDiv);
                setTimeout(function() { successDiv.fadeOut('slow', function() { $(this).remove(); }); }, 3000);
            }

            // Загружаем комментарии при загрузке страницы
            loadComments();

            // Добавление в корзину
            $('.add-to-cart-btn').click(function() {
                var carId = $(this).data('car-id');
                var button = $(this);
                var originalHtml = button.html();

                button.html('<i class="bi bi-hourglass-split"></i> Добавляется...');
                button.prop('disabled', true);

                $.ajax({
                    url: '/Cart/Add',
                    type: 'POST',
                    data: { carId: carId, quantity: 1 },
                    success: function(response) {
                        if (response.success) {
                            button.html('<i class="bi bi-check-circle"></i> Добавлено в корзину!');
                            button.removeClass('btn-yellow').addClass('btn-success');

                            setTimeout(function() {
                                button.html(originalHtml);
                                button.removeClass('btn-success').addClass('btn-yellow');
                                button.prop('disabled', false);
                            }, 2000);
                        } else {
                            alert(response.message || 'Ошибка при добавлении');
                            button.html(originalHtml);
                            button.prop('disabled', false);
                        }
                    },
                    error: function(xhr) {
                        if (xhr.status === 401) {
                            alert('Необходимо войти в систему');
                            window.location.href = '/Account/Login';
                        } else {
                            alert('Ошибка при добавлении в корзину');
                        }
                        button.html(originalHtml);
                        button.prop('disabled', false);
                    }
                });
            });

            // Добавление в избранное
            $('.add-to-wishlist-btn').click(function() {
                var carId = $(this).data('car-id');
                var button = $(this);
                var originalHtml = button.html();

                button.html('<i class="bi bi-hourglass-split"></i> Добавляется...');
                button.prop('disabled', true);

                $.ajax({
                    url: '/Wishlist/Add',
                    type: 'POST',
                    data: { carId: carId },
                    success: function(response) {
                        if (response.success) {
                            button.html('<i class="bi bi-check-circle"></i> Добавлено в избранное!');
                            setTimeout(function() {
                                button.html(originalHtml);
                                button.prop('disabled', false);
                            }, 2000);
                        } else {
                            alert(response.message || 'Ошибка при добавлении');
                            button.html(originalHtml);
                            button.prop('disabled', false);
                        }
                    },
                    error: function(xhr) {
                        if (xhr.status === 401) {
                            alert('Необходимо войти в систему');
                            window.location.href = '/Account/Login';
                        } else {
                            alert('Ошибка при добавлении в избранное');
                        }
                        button.html(originalHtml);
                        button.prop('disabled', false);
                    }
                });
            });
        });
    </script>
}