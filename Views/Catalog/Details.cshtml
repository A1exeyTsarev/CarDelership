@model CarDelership.Models.Cars
@{
    ViewData["Title"] = Model?.Name ?? "Автомобиль";
}

<!-- Генерация AntiForgeryToken -->
@Html.AntiForgeryToken()

@if (Model != null)
{
    <div class="container my-5">
        <div class="row">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                    @{
                        var mainImage = Model.CarImages?.FirstOrDefault();
                        string imagePath = mainImage != null && !string.IsNullOrEmpty(mainImage.ImageName)
                        ? $"/images/{mainImage.ImageName}"
                        : "/images/logo.jpg";
                    }
                    <img src="@imagePath"
                         class="img-fluid"
                         alt="@Model.Name"
                         style="min-height: 300px; object-fit: cover;"
                         onerror="this.src='/images/logo.jpg'" />
                </div>
            </div>

            <div class="col-md-6">
                <h1 class="fw-bold mb-3">@Model.Name</h1>

                <div class="mb-3">
                    <span class="badge bg-secondary">@Model.Year год</span>
                    <span class="badge bg-secondary ms-2">@Model.Mileage.ToString("N0") км</span>
                    @if (Model.AvailabilityStatus == "В наличии")
                    {
                        <span class="badge bg-success ms-2">В наличии</span>
                    }
                    else
                    {
                        <span class="badge bg-warning ms-2">@Model.AvailabilityStatus</span>
                    }
                </div>

                <hr>

                <div class="row mb-4">
                    <div class="col-6">
                        <small class="text-muted">Производитель</small>
                        <p class="fw-bold mb-0">@Model.Model?.Manufacturer?.Name</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">Модель</small>
                        <p class="fw-bold mb-0">@Model.Model?.Name</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">Кузов</small>
                        <p class="fw-bold mb-0">@Model.Model?.BodyType?.Name</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">Цвет</small>
                        <p class="fw-bold mb-0">@Model.Color?.Name</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">Двигатель</small>
                        <p class="fw-bold mb-0">@Model.Model?.EngineType?.Name</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">Мощность</small>
                        <p class="fw-bold mb-0">@Model.Model?.Power л.с.</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">КПП</small>
                        <p class="fw-bold mb-0">@Model.Model?.Transmission?.Name</p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">VIN номер</small>
                        <p class="fw-bold mb-0">@(Model.VIN ?? "Не указан")</p>
                    </div>
                </div>

                <hr>

                @{
                    var discountPercent = 0;
                    if (Model.DiscountPrice > 0 && Model.DiscountPrice < Model.Price)
                    {
                        discountPercent = (int)((1 - (double)Model.DiscountPrice / (double)Model.Price) * 100);
                    }
                }

                @if (discountPercent > 0)
                {
                    <div class="mb-3">
                        <small class="text-muted text-decoration-line-through">@Model.Price.ToString("N0") ₽</small>
                        <span class="fs-1 text-warning fw-bold">@Model.DiscountPrice.ToString("N0") ₽</span>
                        <span class="badge bg-warning text-dark fs-6 ms-2">-@discountPercent%</span>
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <span class="fs-1 text-warning fw-bold">@Model.Price.ToString("N0") ₽</span>
                    </div>
                }

                <div class="mt-4">
                    <button class="btn btn-yellow btn-lg w-100 add-to-cart-btn" data-car-id="@Model.Car_Id">
                        <i class="bi bi-cart-plus"></i> Добавить в корзину
                    </button>
                    <button class="btn btn-outline-yellow btn-lg w-100 mt-2 add-to-wishlist-btn" data-car-id="@Model.Car_Id">
                        <i class="bi bi-heart"></i> Добавить в избранное
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="row mt-5">
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-3">
                        <div class="card-header bg-white border-0">
                            <h5 class="mb-0 fw-bold">
                                <i class="bi bi-file-text text-warning"></i> Описание
                            </h5>
                        </div>
                        <div class="card-body">
                            <p class="mb-0">@Model.Description</p>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- БЛОК ОТЗЫВОВ -->
        <div class="row mt-5">
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-header bg-white border-0">
                        <h5 class="mb-0 fw-bold">
                            <i class="bi bi-chat-dots text-warning"></i> Отзывы
                            <span id="commentsCount" class="badge bg-secondary ms-2">0</span>
                        </h5>
                    </div>
                    <div class="card-body">
                        <!-- Форма добавления комментария -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Оставить отзыв</label>
                            <textarea id="commentText" class="form-control mb-2" rows="3"
                                  placeholder="Поделитесь своим мнением об автомобиле..."></textarea>
                            <button id="submitCommentBtn" class="btn btn-yellow" data-car-id="@Model.Car_Id">
                                <i class="bi bi-send"></i> Отправить отзыв
                            </button>
                        </div>

                        <hr>

                        <!-- Список комментариев -->
                        <div id="commentsList">
                            <div class="text-center text-muted py-3">
                                <i class="bi bi-chat-dots"></i> Загрузка отзывов...
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12">
                <a href="/Catalog" class="btn btn-outline-yellow">
                    <i class="bi bi-arrow-left"></i> Назад в каталог
                </a>
            </div>
        </div>
    </div>
}
else
{
    <div class="container my-5">
        <div class="alert alert-danger text-center">
            <h3><i class="bi bi-exclamation-triangle"></i> Автомобиль не найден</h3>
            <a href="/Catalog" class="btn btn-yellow mt-3">Вернуться в каталог</a>
        </div>
    </div>
}
