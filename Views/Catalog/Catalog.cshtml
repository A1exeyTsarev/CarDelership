@using CarDelership.Models.ViewModels
@model CatalogViewModel
@{
    ViewData["Title"] = "Каталог автомобилей";
}

@section Styles {
    <style>
        .filter-sidebar {
            background: #f8f9fa;
            border-radius: 15px;
            padding: 20px;
            position: sticky;
            top: 20px;
        }
        
        .filter-title {
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid #ffc107;
        }
        
        .tag-filter {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }
        
        .tag-checkbox {
            display: none;
        }
        
        .tag-label {
            background: #e9ecef;
            padding: 5px 12px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 0.85rem;
        }
        
        .tag-checkbox:checked + .tag-label {
            background: #ffc107;
            color: #000;
        }
        
        .sort-select {
            width: auto;
            display: inline-block;
            border-radius: 10px;
            padding: 8px 15px;
        }
        
        .car-card {
            transition: transform 0.3s, box-shadow 0.3s;
            border: none;
            border-radius: 15px;
            overflow: hidden;
            cursor: pointer;
        }
        
        .car-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        }
        
        .car-card img {
            height: 180px;
            object-fit: cover;
        }
        
        .car-price {
            font-size: 1.2rem;
            font-weight: bold;
            color: #e74c3c;
        }
        
        .car-old-price {
            text-decoration: line-through;
            color: #999;
            font-size: 0.85rem;
            margin-right: 8px;
        }
        
        .discount-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background: #ffc107;
            color: #000;
            padding: 4px 8px;
            border-radius: 5px;
            font-weight: bold;
            font-size: 11px;
            z-index: 10;
        }
        
        .pagination {
            justify-content: center;
        }
        
        .page-link {
            color: #ffc107;
        }
        
        .page-item.active .page-link {
            background-color: #ffc107;
            border-color: #ffc107;
            color: #000;
        }
        
        .price-input {
            width: 100%;
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 8px;
        }
        
        .btn-filter {
            background-color: #ffc107;
            color: #000;
            border: none;
            width: 100%;
            padding: 10px;
            border-radius: 10px;
            font-weight: bold;
        }
        
        .btn-reset {
            background-color: #6c757d;
            color: white;
            border: none;
            width: 100%;
            padding: 10px;
            border-radius: 10px;
            margin-top: 10px;
        }
        
        .btn-yellow {
            background-color: #ffc107;
            color: #000;
            border: none;
            transition: all 0.3s ease;
            font-weight: bold;
        }
        
        .btn-yellow:hover {
            background-color: #ffb300;
            transform: translateY(-2px);
        }
    </style>
}

<!-- Хлебные крошки -->
<div class="container mt-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Главная</a></li>
            <li class="breadcrumb-item active">Каталог</li>
        </ol>
    </nav>
</div>

<div class="container my-4">
    <div class="row">
        <!-- Боковая панель с фильтрами -->
        <div class="col-md-3">
            <div class="filter-sidebar">
                <h4 class="filter-title">🔍 Фильтры</h4>
                
                <form method="get" id="filterForm" action="/Catalog/Catalog">
                    <!-- Поиск -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">Поиск</label>
                        <input type="text" name="searchTerm" class="form-control" 
                               placeholder="Название автомобиля..." 
                               value="@Model.SearchTerm">
                    </div>
                    
                    <!-- Цена -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">Цена</label>
                        <div class="row g-2">
                            <div class="col-6">
                                <input type="number" name="minPrice" class="price-input" 
                                       placeholder="от" value="@Model.MinPrice">
                            </div>
                            <div class="col-6">
                                <input type="number" name="maxPrice" class="price-input" 
                                       placeholder="до" value="@Model.MaxPrice">
                            </div>
                        </div>
                    </div>
                    
                    <!-- Год -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">Год выпуска</label>
                        <select name="selectedYear" class="form-select">
                            <option value="">Все годы</option>
                            @foreach (var year in Model.Years)
                            {
                                <option value="@year" selected="@(Model.SelectedYear == year)">@year</option>
                            }
                        </select>
                    </div>
                    
                    <!-- Теги -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">🏷️ Теги</label>
                        <div class="tag-filter">
                            @foreach (var tag in Model.Tags)
                            {
                                <div>
                                    <input type="checkbox" name="selectedTags" value="@tag.Tag_Id" 
                                           id="tag_@tag.Tag_Id" class="tag-checkbox"
                                           @(Model.SelectedTagIds.Contains(tag.Tag_Id) ? "checked" : "")>
                                    <label for="tag_@tag.Tag_Id" class="tag-label">@tag.Name</label>
                                </div>
                            }
                        </div>
                    </div>
                    
                    <button type="submit" class="btn-filter">Применить фильтры</button>
                    <a href="/Catalog/Catalog" class="btn-reset btn">Сбросить все</a>
                </form>
            </div>
        </div>
        
        <!-- Основная область с товарами -->
        <div class="col-md-9">
            <!-- Сортировка и результаты -->
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
                <div>
                    <span class="text-muted">Найдено: @Model.TotalCount автомобилей</span>
                </div>
                <div>
                    <label class="me-2">Сортировать:</label>
                    <select class="sort-select" id="sortSelect">
                        <option value="name_asc" selected="@(Model.SortBy == "name_asc")">По названию (А-Я)</option>
                        <option value="price_asc" selected="@(Model.SortBy == "price_asc")">По цене (возрастание)</option>
                        <option value="price_desc" selected="@(Model.SortBy == "price_desc")">По цене (убывание)</option>
                        <option value="year_desc" selected="@(Model.SortBy == "year_desc")">Сначала новые</option>
                        <option value="year_asc" selected="@(Model.SortBy == "year_asc")">Сначала старые</option>
                    </select>
                </div>
            </div>
            
            <!-- Сетка товаров -->
            @if (Model.Cars.Any())
            {
                <div class="row g-4">
                    @foreach (var car in Model.Cars)
                    {
                        <div class="col-md-4 col-sm-6">
                            <div class="card car-card h-100" onclick="location.href='/Catalog/Details/@car.Car_Id'">
                                <div style="position: relative;">
                                    @{
                                        var discountPercent = 0;
                                        if (car.DiscountPrice > 0 && car.DiscountPrice < car.Price)
                                        {
                                            discountPercent = (int)((1 - (double)car.DiscountPrice / (double)car.Price) * 100);
                                        }
                                    }
                                    @if (discountPercent > 0)
                                    {
                                        <div class="discount-badge">-@discountPercent%</div>
                                    }
                                    <img src="/images/cars/default-car.jpg" class="card-img-top" alt="@car.Name">
                                </div>
                                <div class="card-body">
                                    <h5 class="card-title">@car.Name</h5>
                                    <p class="card-text text-muted small">@car.Year г.</p>
                                    <div class="price-block">
                                        @if (discountPercent > 0)
                                        {
                                            <span class="car-old-price">@car.Price.ToString("N0") ₽</span>
                                            <span class="car-price">@car.DiscountPrice.ToString("N0") ₽</span>
                                        }
                                        else
                                        {
                                            <span class="car-price">@car.Price.ToString("N0") ₽</span>
                                        }
                                    </div>
                                    <div class="mt-2">
                                        @if (car.CarTags != null && car.CarTags.Any())
                                        {
                                            foreach (var carTag in car.CarTags.Take(2))
                                            {
                                                <span class="badge bg-secondary me-1">@carTag.Tag?.Name</span>
                                            }
                                        }
                                    </div>
                                    <div class="d-flex gap-2 mt-3">
                                        <button class="btn btn-yellow flex-grow-1 add-to-cart-btn" data-car-id="@car.Car_Id">
                                            🛒 В корзину
                                        </button>
                                        <button class="btn btn-outline-secondary add-to-wishlist" data-car-id="@car.Car_Id">
                                            ❤️
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                
                <!-- Пагинация -->
                if (Model.TotalPages > 1)
                {
                    <nav class="mt-5">
                        <ul class="pagination">
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="#" data-page="@i">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <h3>😢 Ничего не найдено</h3>
                    <p class="text-muted">Попробуйте изменить параметры поиска</p>
                    <a href="/Catalog/Catalog" class="btn btn-yellow">Сбросить фильтры</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Сортировка
            $('#sortSelect').change(function() {
                var sortBy = $(this).val();
                var url = new URL(window.location.href);
                url.searchParams.set('sortBy', sortBy);
                window.location.href = url.toString();
            });
            
            // Пагинация
            $('.page-link').click(function(e) {
                e.preventDefault();
                var page = $(this).data('page');
                var url = new URL(window.location.href);
                url.searchParams.set('page', page);
                window.location.href = url.toString();
            });
            
            // Добавление в корзину
            $('.add-to-cart-btn').click(function(e) {
                e.stopPropagation();
                var carId = $(this).data('car-id');
                var button = $(this);
                
                $.ajax({
                    url: '/Cart/AddToCart',
                    type: 'POST',
                    data: { carId: carId, quantity: 1 },
                    beforeSend: function() {
                        button.html('⏳...');
                        button.prop('disabled', true);
                    },
                    success: function(response) {
                        if (response.success) {
                            button.html('✓ Добавлено');
                            setTimeout(function() {
                                button.html('🛒 В корзину');
                                button.prop('disabled', false);
                            }, 2000);
                            showNotification('Товар добавлен в корзину!', 'success');
                        } else {
                            button.html('🛒 В корзину');
                            button.prop('disabled', false);
                            showNotification(response.message || 'Ошибка', 'error');
                        }
                    },
                    error: function() {
                        button.html('🛒 В корзину');
                        button.prop('disabled', false);
                        showNotification('Ошибка', 'error');
                    }
                });
            });
        });
        
        function showNotification(message, type) {
            Swal.fire({
                icon: type,
                title: type === 'success' ? 'Готово!' : 'Ошибка',
                text: message,
                timer: 1500,
                showConfirmButton: false
            });
        }
    </script>
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
}