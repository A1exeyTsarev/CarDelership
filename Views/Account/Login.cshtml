@model CarDelership.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Вход в аккаунт";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white text-center py-4">
                    <img src="~/images/logo.jpg" alt="Logo" height="50" class="mb-2">
                        <h3 class="mb-0">Вход в аккаунт</h3>
                        <p class="text-muted mb-0">Добро пожаловать!</p>
                    </div>
                    <div class="card-body p-4">
                        @if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                @TempData["Success"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <form asp-action="Login" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                            <div class="mb-3">
                                <label asp-for="Login" class="form-label fw-bold">
                                    <i class="bi bi-person"></i> Логин
                                </label>
                                <input asp-for="Login" class="form-control form-control-lg" placeholder="Введите ваш логин" autofocus />
                                <span asp-validation-for="Login" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-bold">
                                    <i class="bi bi-lock"></i> Пароль
                                </label>
                                <input asp-for="Password" class="form-control form-control-lg" placeholder="Введите пароль" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <div class="mb-3 form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label">Запомнить меня</label>
                            </div>

                            <button type="submit" class="btn btn-yellow w-100 py-2 fw-bold">
                                <i class="bi bi-box-arrow-in-right"></i> Войти
                            </button>
                        </form>

                        <hr class="my-4">

                        <div class="text-center">
                            <p class="mb-0">Еще нет аккаунта?</p>
                            <a asp-action="Register" class="btn btn-outline-yellow mt-2 w-100">
                                <i class="bi bi-person-plus"></i> Зарегистрироваться
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>