@{
    ViewData["Title"] = "Оформление заказа";
    var deliveryMethods = ViewBag.DeliveryMethods as IEnumerable<CarDelership.Models.DeliveryMethods>;
    var cartItems = ViewBag.CartItems as IEnumerable<CarDelership.Models.ShoppingCart>;
    decimal subtotal = ViewBag.Subtotal ?? 0;
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-truck me-2" style="color: #ffc107;"></i>
                        Оформление заказа
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Отображение ошибок валидации -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="border-left: 4px solid #ffc107;">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Ошибка!</strong> Пожалуйста, исправьте следующие ошибки
                    </div>

                    <!-- Отображение TempData ошибок -->
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-left: 4px solid #ffc107;">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form method="post" id="checkoutForm">
                        @Html.AntiForgeryToken()

                        <h6 class="fw-bold mb-3">
                            Способ доставки <span class="text-danger">*</span>
                        </h6>

                        @if (deliveryMethods != null && deliveryMethods.Any())
                        {
                            <div class="delivery-methods-list">
                                @foreach (var method in deliveryMethods)
                                {
                                    <div class="form-check mb-3 p-3 border rounded" style="transition: all 0.3s ease; cursor: pointer;"
                                         onmouseover="this.style.backgroundColor='#f8f9fa'"
                                         onmouseout="this.style.backgroundColor='transparent'">
                                        <input class="form-check-input delivery-method" type="radio"
                                               name="deliveryMethodId" value="@method.DeliveryMethods_Id"
                                               id="delivery_@method.DeliveryMethods_Id"
                                               data-price="@method.Price">
                                        <label class="form-check-label d-flex justify-content-between align-items-center w-100"
                                               for="delivery_@method.DeliveryMethods_Id">
                                            <span>
                                                <i class="bi bi-truck me-2" style="color: #ffc107;"></i>
                                                <strong>@method.Name</strong>
                                            </span>
                                            <span class="fw-bold" style="color: #ffc107;">
                                                @method.Price.ToString("N0") ₽
                                            </span>
                                        </label>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning" style="border-left: 4px solid #ffc107;">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                Способы доставки не найдены. Обратитесь к администратору.
                            </div>
                        }

                        <hr class="my-4">

                        <button type="submit" class="btn btn-yellow w-100 py-2" id="submitBtn">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            Подтвердить заказ
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-calculator-fill me-2" style="color: #ffc107;"></i>
                        Стоимость заказа
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Товары:</span>
                        <span class="fw-bold" id="subtotal">@subtotal.ToString("N0")</span> ₽
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Доставка:</span>
                        <span class="fw-bold" id="delivery-price">0</span> ₽
                    </div>
                    <hr class="my-3" style="border-top: 2px dashed #ffc107;">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold fs-5">Итого:</span>
                        <span class="fw-bold fs-3" style="color: #ffc107;" id="total">@subtotal.ToString("N0")</span> ₽
                    </div>

                    @if (cartItems != null && cartItems.Any())
                    {
                        <hr class="my-3">
                        <div class="mt-3">
                            <small class="text-muted">
                                <i class="bi bi-info-circle-fill me-1"></i>
                                В корзине: @cartItems.Sum(i => i.Quantity) товар(ов)
                            </small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            let subtotal = @subtotal;

            // Обработка изменения способа доставки
            $('.delivery-method').change(function() {
                let deliveryPrice = parseInt($(this).data('price')) || 0;
                let total = subtotal + deliveryPrice;

                $('#delivery-price').text(deliveryPrice.toLocaleString());
                $('#total').text(total.toLocaleString());

                // Анимация обновления цены
                $('#total').addClass('animate__animated animate__pulse');
                setTimeout(() => {
                    $('#total').removeClass('animate__animated animate__pulse');
                }, 500);
            });

            // Валидация перед отправкой формы
            $('#checkoutForm').on('submit', function(e) {
                let selectedMethod = $('input[name="deliveryMethodId"]:checked').val();

                if (!selectedMethod) {
                    e.preventDefault();
                    showError('Пожалуйста, выберите способ доставки');
                    return false;
                }
                return true;
            });

            // Функция отображения ошибки
            function showError(message) {
                // Удаляем существующее сообщение об ошибке
                $('.custom-error').remove();

                // Создаем новое сообщение
                let errorHtml = `
                    <div class="alert alert-danger alert-dismissible fade show custom-error" role="alert" style="border-left: 4px solid #ffc107;">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Ошибка!</strong> ${message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                `;

                // Вставляем сообщение в начало формы
                $('#checkoutForm').prepend(errorHtml);

                // Прокручиваем к сообщению об ошибке
                $('html, body').animate({
                    scrollTop: $('.custom-error').offset().top - 100
                }, 500);

                // Автоматически скрываем через 5 секунд
                setTimeout(function() {
                    $('.custom-error').fadeOut('slow', function() {
                        $(this).remove();
                    });
                }, 5000);
            }

            // Если нет выбранного метода, показываем подсказку
            if ($('.delivery-method:checked').length === 0) {
                let infoHtml = `
                    <div class="alert alert-info alert-dismissible fade show mb-3" role="alert" style="border-left: 4px solid #ffc107; background-color: #fff3cd;">
                        <i class="bi bi-info-circle-fill me-2" style="color: #ffc107;"></i>
                        <strong>Внимание!</strong> Пожалуйста, выберите способ доставки для оформления заказа
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                `;
                $('#checkoutForm').prepend(infoHtml);
            } else {
                // Если выбран, обновляем итоговую сумму
                $('.delivery-method:checked').trigger('change');
            }

            // Подсветка обязательного поля при попытке отправки без выбора
            $('#submitBtn').on('click', function() {
                if ($('.delivery-method:checked').length === 0) {
                    $('h6:contains("Способ доставки")').css({
                        'color': '#dc3545',
                        'transition': 'color 0.3s ease'
                    });
                    setTimeout(function() {
                        $('h6:contains("Способ доставки")').css('color', '');
                    }, 2000);
                }
            });

            // Добавляем эффект наведения на блоки доставки
            $('.form-check.mb-3').hover(
                function() {
                    $(this).css({
                        'transform': 'translateX(5px)',
                        'transition': 'all 0.3s ease'
                    });
                },
                function() {
                    $(this).css('transform', 'translateX(0)');
                }
            );
        });
    </script>
}