@model CarDelership.Models.Cars
@{
    ViewData["Title"] = "Редактирование автомобиля";
    var models = ViewBag.Models as IEnumerable<CarDelership.Models.CarModels>;
    var colors = ViewBag.Colors as IEnumerable<CarDelership.Models.Color>;
    var statuses = ViewBag.AvailabilityStatuses as List<string>;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-pencil-square me-2" style="color: #ffc107;"></i>
                        Редактирование автомобиля: @Model.Name
                    </h5>
                </div>
                <div class="card-body">
                    <form method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Car_Id" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Название</label>
                                <input asp-for="Name" class="form-control" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Модель</label>
                                <select asp-for="model_Id" class="form-select" required>
                                    <option value="">Выберите модель</option>
                                    @if (models != null)
                                    {
                                        foreach (var m in models)
                                        {
                                            if (m.Model_Id == Model.model_Id)
                                            {
                                                <option value="@m.Model_Id" selected>@m.Manufacturer?.Name - @m.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@m.Model_Id">@m.Manufacturer?.Name - @m.Name</option>
                                            }
                                        }
                                    }
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Цвет</label>
                                <select asp-for="Color_Id" class="form-select">
                                    <option value="">Выберите цвет</option>
                                    @if (colors != null)
                                    {
                                        foreach (var color in colors)
                                        {
                                            if (color.Color_Id == Model.Color_Id)
                                            {
                                                <option value="@color.Color_Id" selected>@color.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@color.Color_Id">@color.Name</option>
                                            }
                                        }
                                    }
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Цена</label>
                                <input asp-for="Price" type="number" class="form-control" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Цена со скидкой</label>
                                <input asp-for="DiscountPrice" type="number" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Год выпуска</label>
                                <input asp-for="Year" type="number" class="form-control" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Пробег (км)</label>
                                <input asp-for="Mileage" type="number" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Количество на складе</label>
                                <input asp-for="Quantity" type="number" class="form-control" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Статус</label>
                                <select asp-for="AvailabilityStatus" class="form-select">
                                    @if (statuses != null)
                                    {
                                        foreach (var status in statuses)
                                        {
                                            if (status == Model.AvailabilityStatus)
                                            {
                                                <option value="@status" selected>@status</option>
                                            }
                                            else
                                            {
                                                <option value="@status">@status</option>
                                            }
                                        }
                                    }
                                </select>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">VIN номер</label>
                                <input asp-for="VIN" class="form-control" />
                            </div>

                            <div class="col-12 mb-3">
                                <label class="form-label fw-bold">Описание</label>
                                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            </div>

                            <div class="col-12 mb-3">
                                <label class="form-label fw-bold">Фотографии</label>

                                @if (Model.CarImages != null && Model.CarImages.Any())
                                {
                                    <div class="row mb-3">
                                        @foreach (var img in Model.CarImages)
                                        {
                                            <div class="col-md-3 mb-2">
                                                <div class="card">
                                                    <img src="/images/@img.ImageName" class="card-img-top" style="height: 100px; object-fit: cover;">
                                                    <div class="card-body p-2 text-center">
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="checkbox" name="deleteImages" value="@img.Image_Id" id="delete_@img.Image_Id">
                                                            <label class="form-check-label small" for="delete_@img.Image_Id">Удалить</label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }

                                <div class="mb-3">
                                    <label class="form-label">Добавить новые фото</label>
                                    <input type="file" name="images" class="form-control" multiple accept="image/*" />
                                    <small class="text-muted">Можно выбрать несколько файлов</small>
                                </div>
                            </div>
                        </div>

                        <hr>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-yellow">
                                <i class="bi bi-save"></i> Сохранить
                            </button>
                            <a href="/CarManagement/Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Назад
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>