@model IEnumerable<CarDelership.Models.Feedback>
@{
    ViewData["Title"] = "Поддержка";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="bi bi-headset me-2" style="color: #ffc107;"></i>
            Мои обращения в поддержку
        </h2>
        <a href="/Support/Create" class="btn btn-yellow">
            <i class="bi bi-plus-lg"></i> Новое обращение
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-chat-dots fs-1 text-muted"></i>
                <h5 class="mt-3">У вас пока нет обращений</h5>
                <p class="text-muted">Создайте новое обращение, и мы поможем вам</p>
                <a href="/Support/Create" class="btn btn-yellow">Создать обращение</a>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var feedback in Model)
            {
                <div class="col-md-6 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h6 class="mb-0">
                                    <i class="bi bi-envelope me-2"></i>
                                    @feedback.Subject
                                </h6>
                                @{
                                    var statusClass = feedback.IsClosed || feedback.IsClosedByUser ? "secondary" :
                                    (feedback.IsProcessed ? "success" : "warning");
                                    var statusText = feedback.IsClosed || feedback.IsClosedByUser ? "Закрыто" :
                                    (feedback.IsProcessed ? "Отвечено" : "В обработке");
                                }
                                <span class="badge bg-@statusClass">@statusText</span>
                            </div>

                            <p class="text-muted small mb-2">
                                <i class="bi bi-calendar"></i> @feedback.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                            </p>

                            <p class="mb-3">
                                @(feedback.Message.Length > 100 ? feedback.Message.Substring(0, 100) + "..." : feedback.Message)
                            </p>

                            @if (!string.IsNullOrEmpty(feedback.AdminComment) && feedback.IsProcessed)
                            {
                                <div class="alert alert-info small mb-3">
                                    <i class="bi bi-chat"></i> <strong>Ответ поддержки:</strong><br />
                                    @(feedback.AdminComment.Length > 80 ? feedback.AdminComment.Substring(0, 80) + "..." : feedback.AdminComment)
                                </div>
                            }

                            <div class="btn-group w-100">
                                <a href="/Support/Details/@feedback.Feedback_Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i> Подробнее
                                </a>
                                @if (!feedback.IsClosed && !feedback.IsClosedByUser)
                                {
                                    <button type="button" class="btn btn-outline-secondary btn-sm"
                                            onclick="closeFeedback(@feedback.Feedback_Id)">
                                        <i class="bi bi-check2"></i> Закрыть
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<script>
    function closeFeedback(id) {
        if (confirm('Закрыть обращение? Вы не сможете добавить новые сообщения.')) {
            var token = $('input[name="__RequestVerificationToken"]').val();
            $.ajax({
                url: '/Support/Close/' + id,
                type: 'POST',
                data: { '__RequestVerificationToken': token },
                success: function() {
                    location.reload();
                },
                error: function() {
                    alert('Ошибка при закрытии обращения');
                }
            });
        }
    }
</script>