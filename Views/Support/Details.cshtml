@model CarDelership.Models.Feedback
@{
    ViewData["Title"] = "Детали обращения";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <i class="bi bi-envelope me-2" style="color: #ffc107;"></i>
                            Обращение #@Model.Feedback_Id
                        </h4>
                        <a href="/Support/Index" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Назад
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <div class="row">
                            <div class="col-md-6">
                                <small class="text-muted">Дата создания</small>
                                <p>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted">Статус</small>
                                <p>
                                    @{
                                        var statusClass = Model.IsClosed || Model.IsClosedByUser ? "secondary" : 
                                                        (Model.IsProcessed ? "success" : "warning");
                                        var statusText = Model.IsClosed || Model.IsClosedByUser ? "Закрыто" : 
                                                        (Model.IsProcessed ? "Отвечено" : "В обработке");
                                    }
                                    <span class="badge bg-@statusClass">@statusText</span>
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6>Тема</h6>
                        <p class="bg-light p-3 rounded">@Model.Subject</p>
                    </div>

                    <div class="mb-4">
                        <h6>Ваше сообщение</h6>
                        <div class="bg-light p-3 rounded">
                            @Html.Raw(Model.Message.Replace("\n", "<br />"))
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.AdminComment))
                    {
                        <div class="mb-4">
                            <h6 class="text-success">
                                <i class="bi bi-chat"></i> Ответ поддержки
                            </h6>
                            <div class="bg-success bg-opacity-10 p-3 rounded border-start border-success border-4">
                                @Html.Raw(Model.AdminComment.Replace("\n", "<br />"))
                                <hr />
                                <small class="text-muted">
                                    @(Model.ProcessedAt?.ToString("dd.MM.yyyy HH:mm")) - @Model.ProcessedBy
                                </small>
                            </div>
                        </div>
                    }

                    @if (!Model.IsClosed && !Model.IsClosedByUser)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-info-circle"></i>
                            Если ваша проблема решена, вы можете закрыть обращение.
                        </div>
                        
                        <form method="post" action="/Support/Close/@Model.Feedback_Id">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-success" 
                                    onclick="return confirm('Закрыть обращение?')">
                                <i class="bi bi-check2"></i> Закрыть обращение
                            </button>
                        </form>
                    }
                    else if (Model.IsClosed || Model.IsClosedByUser)
                    {
                        <div class="alert alert-secondary">
                            <i class="bi bi-check-circle"></i>
                            Это обращение закрыто. Если у вас остались вопросы, создайте новое обращение.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>